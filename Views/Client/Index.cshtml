@model IEnumerable<Client>

@{
    ViewData["Title"] = "Clients";
}

<div style="margin-bottom: 2rem;">
    <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;">👥 Clients</h1>
    <p style="color: #666;">Manage your client portfolio</p>
</div>

<p style="margin-bottom: 2rem;">
    <a asp-action="Create" class="btn btn-primary">➕ Create New Client</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Name)</th>
            <th>@Html.DisplayNameFor(model => model.Email)</th>
            <th>@Html.DisplayNameFor(model => model.PhoneNumber)</th>
            <th>@Html.DisplayNameFor(model => model.Region)</th>
            <th>@Html.DisplayNameFor(model => model.ContactPerson)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Name)</td>
                <td>@Html.DisplayFor(modelItem => item.Email)</td>
                <td>@Html.DisplayFor(modelItem => item.PhoneNumber)</td>
                <td>@Html.DisplayFor(modelItem => item.Region)</td>
                <td>@Html.DisplayFor(modelItem => item.ContactPerson)</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.ClientId" class="btn btn-sm btn-info">👁️ Details</a>
                    <a asp-action="Edit" asp-route-id="@item.ClientId" class="btn btn-sm btn-warning">✏️ Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.ClientId" class="btn btn-sm btn-danger">🗑️ Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
