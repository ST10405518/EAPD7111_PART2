@model EAPD7111_PART2.Models.Contract

@{
    ViewData["Title"] = "Create Contract";
}

<h1>Create Contract</h1>

<h4>Contract</h4>
<hr />
<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>
            <div class="form-group mb-3">
                <label asp-for="ClientId" class="control-label">Client</label>
                <select asp-for="ClientId" class="form-select" asp-items="@(new SelectList(ViewBag.Clients, "ClientId", "Name"))">
                    <option value="">-- Select Client --</option>
                </select>
                <span asp-validation-for="ClientId" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="ContractNumber" class="control-label"></label>
                <input asp-for="ContractNumber" class="form-control" placeholder="e.g. CTR-2026-001" />
                <span asp-validation-for="ContractNumber" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="StartDate" class="control-label"></label>
                        <input asp-for="StartDate" class="form-control" type="date" />
                        <span asp-validation-for="StartDate" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="EndDate" class="control-label"></label>
                        <input asp-for="EndDate" class="form-control" type="date" />
                        <span asp-validation-for="EndDate" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<ContractStatus>()"></select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="ServiceLevel" class="control-label">Service Level (SLA)</label>
                <input asp-for="ServiceLevel" class="form-control" placeholder="e.g. Gold - 24hr response" />
                <span asp-validation-for="ServiceLevel" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Description" class="control-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label class="control-label">Signed Agreement (PDF only)</label>
                <input type="file" name="signedAgreement" class="form-control" accept=".pdf,application/pdf" />
                @if (ViewData.ModelState["signedAgreement"]?.Errors.Count > 0)
                {
                    <span class="text-danger">@ViewData.ModelState["signedAgreement"]!.Errors[0].ErrorMessage</span>
                }
                <small class="text-muted">Optional. Maximum file size 50 MB.</small>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
