@model EAPD7111_PART2.Models.Contract
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Edit Contract";
}

<h1>Edit Contract</h1>

<h4>Contract</h4>
<hr />
<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="ContractId" />
            <input type="hidden" asp-for="CreatedDate" />
            <input type="hidden" asp-for="SignedAgreementFilePath" />
            <div class="form-group mb-3">
                <label asp-for="ClientId" class="control-label">Client</label>
                <select asp-for="ClientId" class="form-select" asp-items="ViewBag.ClientList as IEnumerable<SelectListItem>"></select>
                <span asp-validation-for="ClientId" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="ContractNumber" class="control-label"></label>
                <input asp-for="ContractNumber" class="form-control" />
                <span asp-validation-for="ContractNumber" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="StartDate" class="control-label"></label>
                        <input asp-for="StartDate" class="form-control" type="date" />
                        <span asp-validation-for="StartDate" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="EndDate" class="control-label"></label>
                        <input asp-for="EndDate" class="form-control" type="date" />
                        <span asp-validation-for="EndDate" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<ContractStatus>()"></select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="ServiceLevel" class="control-label"></label>
                <input asp-for="ServiceLevel" class="form-control" />
                <span asp-validation-for="ServiceLevel" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Description" class="control-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label class="control-label">Current Signed Agreement</label>
                @if (!string.IsNullOrEmpty(Model.SignedAgreementFilePath))
                {
                    <div>
                        <a asp-action="Download" asp-route-id="@Model.ContractId" class="btn btn-sm btn-info">Download Current File</a>
                    </div>
                }
                else
                {
                    <p class="text-muted">No file uploaded</p>
                }
            </div>
            <div class="form-group mb-3">
                <label class="control-label">Upload New Agreement (PDF only)</label>
                <input type="file" name="signedAgreement" class="form-control" accept=".pdf,application/pdf" />
                @if (ViewData.ModelState["signedAgreement"]?.Errors.Count > 0)
                {
                    <span class="text-danger">@ViewData.ModelState["signedAgreement"]!.Errors[0].ErrorMessage</span>
                }
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
