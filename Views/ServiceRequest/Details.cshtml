@model EAPD7111_PART2.Models.ServiceRequest

@{
    ViewData["Title"] = "Service Request Details";
}

<h1>Service Request Details</h1>

<div>
    <h4>Service Request</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Contract</dt>
        <dd class="col-sm-9">@Model.Contract?.ContractNumber</dd>

        <dt class="col-sm-3">Client</dt>
        <dd class="col-sm-9">@Model.Contract?.Client?.Name</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.RequestNumber)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.RequestNumber)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Description)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Description)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CostUSD)</dt>
        <dd class="col-sm-9">@Model.CostUSD.ToString("C")</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CostZAR)</dt>
        <dd class="col-sm-9">@Model.CostZAR.ToString("C")</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Status)</dt>
        <dd class="col-sm-9">
            <span class="badge @(Model.Status == ServiceRequestStatus.Completed ? "bg-success" : 
                                 Model.Status == ServiceRequestStatus.InProgress ? "bg-primary" : 
                                 Model.Status == ServiceRequestStatus.Cancelled ? "bg-danger" : "bg-warning")">
                @Html.DisplayFor(model => model.Status)
            </span>
        </dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Notes)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Notes)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CreatedDate)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.CreatedDate)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ModifiedDate)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.ModifiedDate)</dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.ServiceRequestId" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
